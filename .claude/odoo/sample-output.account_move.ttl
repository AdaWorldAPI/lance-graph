### account_move._compute_partner_bank_id  [Deterministic / Transitive]
odoo:account_move._compute_partner_bank_id a ogit:Method ;
    ogit:family odoo:account_move ;
    ogit:methodName "_compute_partner_bank_id" ;
    ogit:matchId "odoo_compute" ;
    axis:classification axis:Deterministic ;
    verb:transitivity verb:Transitive ;
    ogit:decorator """@api.depends('bank_partner_id', 'currency_id', 'preferred_payment_method_line_id')""" ;
    ogit:signature """self""" ;
    ogit:bodyLines 26 ;
    rdfs:comment """def _bank_selection_key(bank):
            \"\"\"Sorting priority:
            0. Same currency as the move or no currency
            1. Different currency
            \"\"\"
            if bank.currency_id == move.currency_id or not bank.currency_id:
                currency_priority = 0
            else:
                currency_priority = 1
            return (currency_priority, not bank.allow_out_payment)

        for move in self:
            if move.is_inbound() and (
                payment_method := (
                    move.preferred_payment_method_line_id
                    or move.bank_partner_id.property_inbound_payment_method_line_id
                )
            ) and payment_method.journal_id:
                move.partner_bank_id = payment_method.journal_id.bank_account_id
                continue

            move.partner_bank_id = move.bank_partner_id.bank_ids.filtered(
                lambda bank: not bank.company_id or bank.company_id == move.company_id
            ).sorted(key=_bank_selection_key)[:1]""" ;
    dcterms:source """models/account_move.py:L1038-1063""" .
