### account_move._compute_always_tax_exigible  [Deterministic / Transitive]
odoo:account_move._compute_always_tax_exigible a ogit:Method ;
    ogit:family odoo:account_move ;
    ogit:methodName "_compute_always_tax_exigible" ;
    ogit:matchId "odoo_compute" ;
    axis:classification axis:Deterministic ;
    verb:transitivity verb:Transitive ;
    ogit:decorator """@api.depends('line_ids.account_id.account_type')""" ;
    ogit:signature """self""" ;
    ogit:bodyLines 9 ;
    rdfs:comment """for record in self.with_context(prefetch_fields=False):
            # We need to check is_invoice as well because always_tax_exigible is used to
            # set the tags as well, during the encoding. So, if no receivable/payable
            # line has been created yet, the invoice would be detected as always exigible,
            # and set the tags on some lines ; which would be wrong.
            record.always_tax_exigible = not record.is_invoice(True) \\
                                         and not record._collect_tax_cash_basis_values()""" ;
    dcterms:source """models/account_move.py:L998-1006""" .
