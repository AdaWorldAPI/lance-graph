# ── Healthcare basins 0x10..=0x19 ────────────────────────────────────────────
# These are the basins E1-2 (medcare-rs) depends on: FMA, SNOMED, ICD10,
# RxNorm, LOINC, MONDO, HPO, DRON, CHEBI, RadLex.

ogit:HealthcareFMA
    a ogit:FamilyNamespace ;
    ogit.meta:superDomain "Healthcare" ;
    ogit.meta:familyId    "16"^^xsd:unsignedByte .

ogit:HealthcareSNOMED
    a ogit:FamilyNamespace ;
    ogit.meta:superDomain "Healthcare" ;
    ogit.meta:familyId    "17"^^xsd:unsignedByte .

