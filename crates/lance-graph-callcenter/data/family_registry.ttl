    a ogit:FamilyNamespace ;
    ogit.meta:superDomain "SMB.bson" ;
    ogit.meta:familyId    "164"^^xsd:unsignedByte .

ogit:SmbBsonBank
    a ogit:FamilyNamespace ;
    ogit.meta:superDomain "SMB.bson" ;
    ogit.meta:familyId    "165"^^xsd:unsignedByte .

